# goldfish 환경변수 양식 — 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   cp .env.example .env
# ⚠️ .env 는 절대 커밋하지 마세요 (.gitignore 에 의해 제외됨)

# --- AI (v0.3) ---
# Claude API 키 — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=

# --- 토스증권 조회 API (v0.4, read-only) ---
# ⚠️ 조회 전용. 주문/매매 키는 사용하지 않습니다.
TOSS_APP_KEY=
TOSS_APP_SECRET=
