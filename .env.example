# goldfish 환경변수 양식 — 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   cp .env.example .env
# ⚠️ .env 는 절대 커밋하지 마세요 (.gitignore 에 의해 제외됨)

# --- AI (v0.3, 선택) ---
# Gemini API 키 (무료 티어) — https://aistudio.google.com/apikey 에서 발급
# 없어도 됨: 키가 없으면 통계 분석만 출력 (AI 코칭만 건너뜀)
GEMINI_API_KEY=

# --- 토스증권 조회 API (v0.4, read-only) ---
# ⚠️ 조회 전용. 주문/매매(주문 생성·정정·취소)는 호출하지 않습니다.
# 토스증권 WTS 로그인 → 설정 > Open API 에서 발급 (OAuth2 Client Credentials)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# (선택) 사용할 계좌의 accountSeq. 미지정 시 계좌 목록의 첫 계좌를 사용.
TOSS_ACCOUNT_SEQ=
